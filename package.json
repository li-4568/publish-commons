{
  "name": "publish-commons",
  "version": "1.0.0",
  "description": "公共组件库，封装通用组件、业务需求组件和可定制组件",
  "main": "dist/ant-commons.umd.js",
  "module": "dist/ant-commons.es.js",
  "files": [
    "dist",
    "es",
    "lib"
  ],
  "sideEffects": [
    "*.less",
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:components": "vue-tsc --noEmit && vite build --mode components",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "typecheck": "vue-tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "vue3",
    "components",
    "ui",
    "ant-design-vue",
    "typescript"
  ],
  "author": "liyujie <79983104@qq.com>",
  "license": "MIT",
  "type": "module",
  "peerDependencies": {
    "ant-design-vue": "^4.0.0",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-vue": "^4.5.0",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "less": "^4.2.0",
    "prettier": "^3.8.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0",
    "vue": "^3.3.0",
    "vue-tsc": "^2.2.12"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.0",
    "ant-design-vue": "^4.0.0"
  }
}
