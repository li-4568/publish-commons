{
  "name": "publish-commons",
  "version": "1.0.6",
  "description": "公共组件库，封装通用组件、业务需求组件和可定制组件",
  "main": "dist/publish-commons.umd.js",
  "module": "dist/publish-commons.es.js",
  "private": false,
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.less",
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "vue-tsc --noEmit --skipLibCheck && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "vue3",
    "components",
    "ui",
    "ant-design-vue",
    "typescript"
  ],
  "author": "liyujie <79983104@qq.com>",
  "license": "MIT",
  "type": "module",
  "peerDependencies": {
    "@ant-design/icons-vue": "^7.0.0",
    "@wangeditor/editor": "^5.1.0",
    "ant-design-vue": "^4.0.0",
    "dayjs": "^1.11.0",
    "echarts": "^6.0.0",
    "vue": "^3.3.0",
    "vxe-pc-ui": "~4.13.0",
    "vxe-table": "^4.18.0",
    "xe-utils": "^4.0.0"
  },
  "devDependencies": {
    "@types/echarts": "^4.9.22",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "less": "^4.2.0",
    "prettier": "^3.8.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.2",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.4",
    "vue": "^3.3.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.12"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.0",
    "@vue-office/docx": "^1.6.3",
    "@vue-office/excel": "^1.7.14",
    "@wangeditor/editor": "^5.1.0",
    "@wangeditor/editor-for-vue": "^5.1.12",
    "ant-design-vue": "^4.0.0",
    "echarts": "^6.0.0",
    "v-viewer": "^3.0.23",
    "vue-cropper": "^1.1.4",
    "vxe-pc-ui": "~4.13.0",
    "vxe-table": "^4.18.0",
    "xe-utils": "^4.0.0"
  }
}
